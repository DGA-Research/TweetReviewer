# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# ----- Public hostname / TLS (Caddy) -----
# The domain pointed at your VPS. Caddy auto-provisions HTTPS for it.
# For local testing use: DOMAIN=localhost
DOMAIN=tweets.example.org

# ----- Basic auth (Caddy) -----
# Shared login for the research team.
BASIC_AUTH_USER=research
# Bcrypt hash generated with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
BASIC_AUTH_HASH=REPLACE_WITH_CADDY_HASH

# ----- GitHub storage -----
# Use a fine-grained Personal Access Token scoped to ONLY this repo,
# with Contents: Read and write permission.
GITHUB_TOKEN=github_pat_xxx
GITHUB_OWNER=DGA-Research
GITHUB_REPO=TweetReviewer
GITHUB_BRANCH=feature/Tweet-Reviewer-VPS

# Folders inside the repo where files are stored.
GITHUB_INPUTS_DIR=inputs
GITHUB_REVIEWS_DIR=reviews
